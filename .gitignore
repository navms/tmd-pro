# ------------------------------ Go 核心忽略项 ------------------------------
# Go 编译中间产物
*.o
*.a
*.so
*.dll
*.dylib

# 测试二进制文件
*.test

# Go 模块缓存
go.work
go.work.sum

# 测试覆盖率文件
coverage.out
coverage.html
coverage.xml

# Go 构建缓存（Go 1.16+）
/bin/
/dist/
/build/

# Vendor 目录
vendor/

# macOS 系统文件
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.swp
*.swo
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

.idea/
*.iml
*.iws
*.ipr
out/
.session
.vim/

# 环境变量文件（敏感信息，禁止提交）
.env
.env.local
.env.*.local

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.temp
tmp/
temp/

# 备份文件
*.bak
*.backup
*.old

frontend/dist
frontend/node_modules